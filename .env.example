# Neon Postgres connection string (required)
# Get from: https://console.neon.tech -> your project -> "Connection string"
DATABASE_URL="postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require"

# LinkedIn Developer App credentials (required)
# Get from: https://developer.linkedin.com -> your app -> Auth tab
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""

# OAuth redirect URI — must exactly match one entry in the LinkedIn app's
# "Authorized redirect URLs" list. For local dev use localhost:3000.
LINKEDIN_REDIRECT_URI="http://localhost:3000/auth/linkedin/callback"

# Base URL of this app (used for building absolute URLs)
APP_BASE_URL="http://localhost:3000"

# AES-256-GCM key for encrypting stored LinkedIn tokens at rest.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be 64 hex chars (32 bytes). Keep this secret.
LINKEDIN_TOKEN_ENC_KEY=""

# Feature flag: set "true" only after you've verified posting works.
LINKEDIN_PUBLISH_ENABLED="false"

# App-level access password (optional).
# When set, the whole app is gated by HTTP Basic Auth (any username, this password).
# When unset, the app is fully public — only use that in local dev.
APP_ACCESS_PASSWORD=""

# Shared secret used to authenticate cron callers (Vercel cron + GitHub Actions).
# Generate: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
# Set the same value in Vercel env vars AND in GitHub Actions secret CRON_SECRET.
CRON_SECRET=""

# LinkedIn Posts API version (YYYYMM). Leave default unless LinkedIn bumps it.
LINKEDIN_API_VERSION="202604"
